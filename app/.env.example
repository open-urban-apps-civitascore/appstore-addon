# Copy to .env.local and fill in. Every marketplace instance sets these.

# --- Auth (Keycloak via next-auth) ---
AUTH_SECRET="change-me"
AUTH_KEYCLOAK_ID="marketplace-addon"
AUTH_KEYCLOAK_SECRET="change-me"
AUTH_KEYCLOAK_ISSUER="http://localhost:8080/realms/civitas-core"
AUTH_URL="http://localhost:3001"

# --- CivitasCore portal-backend (the install path) ---
# Base URL of the portal-backend REST API — INCLUDING the /v1 context path.
# Local dev stack (start-portal-dev.sh): the backend listens on :8089 directly;
# :9080 is the APISIX gateway (route /v1/*), :8080 is Keycloak.
# Installs provision a use case by driving the DataSet lifecycle here
# (datastructures → datasource → dataset → datasink/pipeline → stage → release).
PORTAL_BACKEND_BASE_URL="http://localhost:8089/v1"

# The backend is an OAuth2 resource server: every request needs a REAL Keycloak
# JWT (verified 2026-07-14 — the gateway headers alone yield 401). With the
# following set, the marketplace mints + refreshes a token itself (password
# grant; dev only — production forwards the logged-in user's token instead):
PORTAL_BACKEND_KEYCLOAK_URL="http://localhost:8080"
PORTAL_BACKEND_KEYCLOAK_REALM="civitas-core"
PORTAL_BACKEND_KEYCLOAK_CLIENT_ID="admin-cli"
PORTAL_BACKEND_KEYCLOAK_USERNAME="dev@civitas.local"
PORTAL_BACKEND_KEYCLOAK_PASSWORD="dev123"

# `X-Allowed-Scope-Ids` value; "*" is a dev-only placeholder (allow-all mode).
PORTAL_BACKEND_ALLOWED_SCOPE_IDS="*"
# Fallback when the Keycloak vars above are unset: a static dev bearer token
# forwarded as `Authorization: Bearer …` (expires after ~5 min — mint manually).
# PORTAL_BACKEND_BEARER_TOKEN=""

# Where the marketplace records its local installs (use case → provisioned dataset
# id). Optional; defaults to a file in the OS temp dir. Prototype: resettable.
# MARKETPLACE_INSTALL_STORE_PATH="/var/lib/marketplace/installs.json"

# --- Repo-list (the catalog) ---
# Direct raw URL of the catalog index.json (public, no token). Required — with
# it unset the catalog is served empty (there is no catalog bundled with the app).
REPO_LIST_URL="https://gitlab.com/civitascore-openurbanapps/civitas-marketplace-catalog/-/raw/main/index.json"
# Cache lifetime before re-fetching the index (seconds; default 900).
REPO_LIST_TTL_SECONDS="900"
