# Copy to .env.local and fill in. Every marketplace instance sets these.

# --- Auth (Keycloak via next-auth) ---
AUTH_SECRET="change-me"
AUTH_KEYCLOAK_ID="marketplace-addon"
AUTH_KEYCLOAK_SECRET="change-me"
AUTH_KEYCLOAK_ISSUER="http://localhost:8080/realms/civitas-core"
AUTH_URL="http://localhost:3001"

# --- CivitasCore portal-backend (the install path) ---
# Base URL of the portal-backend REST API. Installs provision a use case by driving
# the DataSet lifecycle here (datastructure → datasource → dataset → pipeline/
# datasink → stage → release).
PORTAL_BACKEND_BASE_URL="http://localhost:8080"
# Dev auth stub for the gateway-injected headers. In production these come from a
# Keycloak login + APISIX/OPA (see lib/server/portal-backend/auth.ts TODO), NOT env.
# `X-Allowed-Scope-Ids` value; "*" is a dev-only placeholder.
PORTAL_BACKEND_ALLOWED_SCOPE_IDS="*"
# Optional dev bearer token forwarded as `Authorization: Bearer …`.
# PORTAL_BACKEND_BEARER_TOKEN=""

# Where the marketplace records its local installs (use case → provisioned dataset
# id). Optional; defaults to a file in the OS temp dir. Prototype: resettable.
# MARKETPLACE_INSTALL_STORE_PATH="/var/lib/marketplace/installs.json"

# --- Repo-list (the catalog) ---
# Direct raw URL of the catalog index.json (public, no token). Required — with
# it unset the catalog is served empty (there is no catalog bundled with the app).
REPO_LIST_URL="https://gitlab.com/civitascore-openurbanapps/civitas-marketplace-catalog/-/raw/main/index.json"
# Cache lifetime before re-fetching the index (seconds; default 900).
REPO_LIST_TTL_SECONDS="900"
